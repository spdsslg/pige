<Window x:Class="WpfPractice1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPractice1"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Library Reservation Manager" Height="700" Width="600" MinHeight="600" MinWidth="450" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ObjectDataProvider x:Key="CategoryList"
                        MethodName="GetValues"
                        ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="local:BookCategory"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="ReservedBookBorder" TargetType="{x:Type Border}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReserved}" Value="true">
                    <Setter Property="Background" Value="#FFFFD6D6"/>
                    <Setter Property="BorderBrush" Value="Red"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="BookListItemTemplate" DataType="{x:Type local:Book}">
            <Border Padding="3" BorderThickness="1" BorderBrush="Black" Margin="3" HorizontalAlignment="Stretch" Style="{StaticResource ReservedBookBorder}">
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Grid.Row="1" Text="{Binding Author}" FontSize="14"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <TextBlock Text="{Binding Category}"/>
                        <TextBlock Text=" | "/>
                        <TextBlock Text="{Binding Year}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <CollectionViewSource x:Key="LibraryViewSource" Source="{Binding}"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="2">
            <MenuItem Header="File">
                <MenuItem Header="Exit" Click="MenuItem_Exit"/>
            </MenuItem>
            <MenuItem Header="Books">
                <MenuItem Header="Add book" Click="MenuItem_AddBook"/>
                <MenuItem Header="Clear" Click="MenuItem_ClearBooks"/>
            </MenuItem>
            <MenuItem Header="About" Click="MenuItem_About"/>
        </Menu>

        <ListBox Grid.Column="0" Grid.Row="1" ItemsSource="{Binding Source={StaticResource LibraryViewSource}}" ItemTemplate="{StaticResource BookListItemTemplate}" HorizontalContentAlignment="Stretch" IsSynchronizedWithCurrentItem="True">
            
        </ListBox>

        <Grid Grid.Column="2" Grid.Row="1" DataContext="{Binding Source={StaticResource LibraryViewSource}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.ColumnSpan="2" Content="Selected Book Details" Margin="15,0,0,0"/>
            <Label Grid.Row="1" Grid.Column="0" Content="Title:"/>
            <Label Grid.Row="2" Grid.Column="0" Content="Author:"/>
            <Label Grid.Row="3" Grid.Column="0" Content="ISBN:"/>
            <Label Grid.Row="4" Grid.Column="0" Content="Year:"/>
            <Label Grid.Row="5" Grid.Column="0" Content="Category:"/>

            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Isbn, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>

            <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding Source={StaticResource CategoryList}}" SelectedItem="{Binding Path=Category, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
            <CheckBox Grid.Row="6" Grid.ColumnSpan="2" Content="Is Reserved" IsChecked="{Binding IsReserved, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <TabControl Grid.Row="2" Grid.ColumnSpan="2">
            <TabItem Header="Book Grid">
                <DataGrid  ItemsSource="{Binding Source={StaticResource LibraryViewSource}}" CanUserAddRows="True" AutoGenerateColumns="False" CanUserDeleteRows="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="Author" Binding="{Binding Author, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="ISBN" Binding="{Binding Isbn, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="Year" Binding="{Binding Year, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridComboBoxColumn Header="Category" ItemsSource="{Binding Source={StaticResource CategoryList}}" SelectedItemBinding="{Binding Path=Category, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridCheckBoxColumn Header="Reserved" Binding="{Binding IsReserved, UpdateSourceTrigger=PropertyChanged}"/>

                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Filter">
                <StackPanel Margin="20">
                    <CheckBox x:Name="ReservedOnlyCheckbox" Content="Show Only Reserved Books" Click="CheckBox_Reserved"/>
                    <Label>The Checkbox State is:</Label>
                    <Label Content="{Binding IsChecked, ElementName=ReservedOnlyCheckbox}"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
